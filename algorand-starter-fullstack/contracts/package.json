{
  "name": "@repo/contracts",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./artifacts/HelloWorldClient.ts"
  },
  "engines": {
    "node": ">=22.0"
  },
  "scripts": {
    "build": "algokit compile ts src --output-source-map --out-dir ../artifacts && algokit generate client artifacts --output {app_spec_dir}/{contract_name}Client.ts",
    "test": "npm run build && vitest run",
    "test:watch": "vitest watch",
    "check-types": "tsc --noEmit",
    "deploy": "tsx --env-file=.env.localnet deploy.ts",
    "deploy:testnet": "tsx --env-file=.env.testnet deploy.ts",
    "deploy:mainnet": "tsx --env-file=.env.mainnet deploy.ts"
  },
  "dependencies": {
    "@algorandfoundation/algorand-typescript": "^1.0.1"
  },
  "devDependencies": {
    "@algorandfoundation/algorand-typescript-testing": "^1.0.1",
    "@algorandfoundation/algokit-utils": "^9.0.0",
    "@algorandfoundation/puya-ts": "^1.0.1",
    "@rollup/plugin-typescript": "^12.1.2",
    "@vitest/coverage-v8": "^2.1.8",
    "@types/node": "^22.0.0",
    "algosdk": "^3.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "overrides": {
    "esbuild": "0.25.0"
  }
}
